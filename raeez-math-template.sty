% Memoir-native section formatting.
\makeatletter
\@ifundefined{makechapterstyle}{}{%
  \makechapterstyle{raeezmath}{%
    \renewcommand*{\chapterheadstart}{\vspace*{1.5\baselineskip}}%
    \renewcommand*{\chapnamefont}{\normalfont\small\scshape\lsstyle}%
    \renewcommand*{\chapnumfont}{\normalfont\raeezdisplayfont\Large\scshape\lsstyle}%
    \renewcommand*{\chaptitlefont}{\normalfont\raeezdisplayfont\LARGE\scshape\lsstyle}%
    \renewcommand*{\printchaptername}{\chapnamefont\@chapapp}%
    \renewcommand*{\chapternamenum}{\space}%
    \renewcommand*{\printchapternum}{\chapnumfont\thechapter}%
    \renewcommand*{\afterchapternum}{\par\vskip 0.65\baselineskip}%
    \renewcommand*{\printchaptertitle}[1]{\chaptitlefont ##1}%
    \renewcommand*{\afterchaptertitle}{\par\nobreak\vskip 1.35\baselineskip}%
  }%
  \chapterstyle{raeezmath}%
}
\@ifundefined{setsecheadstyle}{}{%
  \setbeforesecskip{-2.8ex plus -0.8ex minus -0.2ex}%
  \setaftersecskip{1.1ex plus 0.2ex}%
  \setbeforesubsecskip{-2.2ex plus -0.6ex minus -0.2ex}%
  \setaftersubsecskip{0.8ex plus 0.2ex}%
  \setbeforesubsubsecskip{-1.8ex plus -0.5ex minus -0.2ex}%
  \setaftersubsubsecskip{0.55ex plus 0.15ex}%
  \setsecheadstyle{\normalfont\large\scshape\lsstyle}%
  \setsubsecheadstyle{\normalfont\normalsize\itshape}%
  \setsubsubsecheadstyle{\normalfont\normalsize\scshape\lsstyle}%
  \setparaheadstyle{\normalfont\normalsize\itshape}%
}
\@ifundefined{makepagestyle}{}{%
  \nouppercaseheads
  \makepagestyle{raeezmath}%
  \makeevenhead{raeezmath}{\normalfont\small\thepage}{}%
    {\normalfont\small\scshape\lsstyle\leftmark}%
  \makeoddhead{raeezmath}{\normalfont\small\scshape\lsstyle\rightmark}{}%
    {\normalfont\small\thepage}%
  \makeevenfoot{raeezmath}{}{}{}%
  \makeoddfoot{raeezmath}{}{}{}%
  \makeheadrule{raeezmath}{\textwidth}{0pt}%
  \pagestyle{raeezmath}%
  \aliaspagestyle{chapter}{plain}%
}
\makeatother

