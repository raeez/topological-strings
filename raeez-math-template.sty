\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{raeez-math-template}[2026/04/24 shared mathematical monograph template]

% Canonical template for the chiral bar-cobar trilogy.
% The manuscript owns mathematical notation; this package owns typography,
% theorem structure, claim-status display, anchors, and shared diagram styles.

\setcounter{secnumdepth}{4}
\setcounter{tocdepth}{4}

% --------------------------------------------------------------------------
% Font system
% --------------------------------------------------------------------------
%
% The house face is Garamond, but the important constraint is not merely
% "Garamond text": the math italic, operators, subscripts, figures, small
% caps, and page colour must belong to the same optical system.
%
% pdfLaTeX remains the compatibility baseline for the existing manuscripts.
% LuaLaTeX/XeLaTeX are the print-first path: they may use Adobe Garamond
% Premier Pro when the complete family is installed. We never synthesize
% italic, bold, or small caps for the book face.

\def\raeez@font@auto{auto}
\def\raeez@font@premier{premier}
\def\raeez@font@adobepro{adobepro}
\def\raeez@font@adobepropreview{adobepropreview}
\def\raeez@font@ebgaramond{ebgaramond}
\def\raeez@fontprofile{auto}
\newif\ifraeez@subscriptcorrection
\newif\ifraeez@theorems
\raeez@theoremstrue
\ifdefined\raeezfontprofile
  \let\raeez@fontprofile\raeezfontprofile
\fi
\DeclareOption{auto}{\def\raeez@fontprofile{auto}}
\DeclareOption{font=auto}{\def\raeez@fontprofile{auto}}
\DeclareOption{premier}{\def\raeez@fontprofile{premier}}
\DeclareOption{garamondpremier}{\def\raeez@fontprofile{premier}}
\DeclareOption{garamond-premier}{\def\raeez@fontprofile{premier}}
\DeclareOption{adobepremier}{\def\raeez@fontprofile{premier}}
