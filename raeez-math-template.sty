	  \def\raeez@detectpremier{%
	    \IfFontExistsTF{GaramondPremrPro}{%
	      \IfFontExistsTF{GaramondPremrPro-It}{%
	        \IfFontExistsTF{GaramondPremrPro-Smbd}{%
	          \IfFontExistsTF{GaramondPremrPro-SmbdIt}{\raeez@premieravailabletrue}{}%
	        }{}%
	      }{}%
	    }{}%
	  }%
		  \def\raeez@detectadobepro{%
		    \IfFontExistsTF{AGaramondPro-Regular}{%
          \raeez@adobeproregularavailabletrue
		      \IfFontExistsTF{AGaramondPro-Italic}{%
	        \IfFontExistsTF{AGaramondPro-Semibold}{%
	          \IfFontExistsTF{AGaramondPro-SemiboldItalic}{%
	            \raeez@adobeproavailabletrue
	            \def\raeez@adobepro@bold{AGaramondPro-Semibold}%
	            \def\raeez@adobepro@bolditalic{AGaramondPro-SemiboldItalic}%
	          }{}%
	        }{}%
	        \ifraeez@adobeproavailable\else
	          \IfFontExistsTF{AGaramondPro-Bold}{%
	            \IfFontExistsTF{AGaramondPro-BoldItalic}{%
	              \raeez@adobeproavailabletrue
	              \def\raeez@adobepro@bold{AGaramondPro-Bold}%
	              \def\raeez@adobepro@bolditalic{AGaramondPro-BoldItalic}%
	            }{}%
	          }{}%
	        \fi
	      }{}%
		    }{}%
		  }%
		  \def\raeez@detectadobeproregular{%
		    \IfFontExistsTF{AGaramondPro-Regular}{\raeez@adobeproregularavailabletrue}{}%
		  }%
