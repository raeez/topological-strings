\DeclareOption{agaramondpro}{\def\raeez@fontprofile{adobepro}}
\DeclareOption{font=adobepro}{\def\raeez@fontprofile{adobepro}}
\DeclareOption{adobepropreview}{\def\raeez@fontprofile{adobepropreview}}
\DeclareOption{adobe-preview}{\def\raeez@fontprofile{adobepropreview}}
\DeclareOption{adobepreview}{\def\raeez@fontprofile{adobepropreview}}
