	    \raeez@detectpremier
	    \raeez@detectadobepro
	  \else\ifx\raeez@fontprofile\raeez@font@premier
	    \raeez@detectpremier
			  \else\ifx\raeez@fontprofile\raeez@font@adobepro
			    \raeez@detectadobepro
			  \else\ifx\raeez@fontprofile\raeez@font@adobepropreview
			    \raeez@detectadobeproregular
			  \fi\fi\fi\fi
